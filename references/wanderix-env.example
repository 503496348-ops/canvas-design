# 艺游未境-Wanderix · 环境变量配置模板
# 复制为 .env 后填入真实 Key

# ── API Key（必填）───────────────────────────────────────────────
GRSAPI_KEY=your-api-key-here

# ── API 地址（可选）─────────────────────────────────────────────
GRSAPI_URL=https://grsai.dakka.com.cn

# ── 输出目录（可选）──────────────────────────────────────────────
WANDERIX_OUTPUT_DIR=~/Desktop
